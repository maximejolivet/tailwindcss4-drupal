<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Drupal">
  <description>PHP CodeSniffer configuration for this Drupal project.</description>

  <!-- Paths to check -->
  <file>web/modules/custom</file>
  <file>web/themes/custom</file>

  <!-- Apply Drupal coding standards -->
  <rule ref="Drupal"/>
  <rule ref="DrupalPractice"/>

  <!-- PHP 8.4 compatibility -->
  <config name="php_version" value="80400"/>

  <!-- Exclude generated and vendor files -->
  <exclude-pattern>*/node_modules/*</exclude-pattern>
  <exclude-pattern>*/dist/*</exclude-pattern>
  <exclude-pattern>*/vendor/*</exclude-pattern>

  <!-- Only check PHP files -->
  <arg name="extensions" value="php,module,install,inc,profile,theme"/>

  <!-- Show sniff codes to help identify rule origins -->
  <arg value="s"/>
</ruleset>
